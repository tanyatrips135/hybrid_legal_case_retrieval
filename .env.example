# ── Copy this to .env and edit ────────────────────────────────────────────────

# Device: "cpu" or "cuda"
DEVICE=cpu

# Model directories (relative to project root)
LEGAL_BERT_DIR=models/legal_bert_issue_extraction
T5_DIR=models/t5-legal-explainer
SBERT_DIR=models/all-mpnet-base-v2

# FAISS files
FAISS_INDEX=models/all-mpnet-base-v2/legal_cases.faiss
META_JSONL=models/all-mpnet-base-v2/legal_cases_meta.jsonl

# RoBERTa NER — HuggingFace Hub ID or local path
ROBERTA_NER_MODEL=Jean-Baptiste/roberta-large-ner-english

# Retrieval settings
TOP_K_FAISS=20
TOP_K_BM25=20
TOP_K_FINAL=5

# T5 generation
T5_MAX_INPUT_TOKENS=512
T5_MAX_NEW_TOKENS=256
T5_NUM_BEAMS=4
