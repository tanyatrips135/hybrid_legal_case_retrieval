# Device
DEVICE=cpu

# Model directories
LEGAL_BERT_DIR=app/models/legal_bert_issue_extraction
T5_DIR=app/models/bart-legal-summarizer
SBERT_DIR=app/models/all-mpnet-base-v2

# FAISS files
FAISS_INDEX=app/models/all-mpnet-base-v2/legal_cases.faiss
META_JSONL=app/models/all-mpnet-base-v2/legal_cases_meta.jsonl
FULL_TEXT_JSONL=app/models/all-mpnet-base-v2/merged_corpus.jsonl

# RoBERTa
ROBERTA_NER_MODEL=Jean-Baptiste/roberta-large-ner-english

# Retrieval
TOP_K_FAISS=20
TOP_K_BM25=20
TOP_K_FINAL=5
BM25_CACHE_PATH=app/models/all-mpnet-base-v2/bm25_cache.pkl

# Post-retrieval validation
VALIDATION_ENABLED=true
VALIDATION_MODEL=llama-3.3-70b-versatile
VALIDATION_TEMPERATURE=0.1
VALIDATION_ENFORCE_DECISION=false
GROQ_API_KEY=

# T5
T5_MAX_INPUT_TOKENS=1024
T5_MAX_NEW_TOKENS=256
T5_MIN_NEW_TOKENS=128
T5_NUM_BEAMS=4
T5_SUMMARY_SENTENCES=4
